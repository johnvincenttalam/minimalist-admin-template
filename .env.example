# Copy this file to .env.local and fill in values for your project.
# All variables must be prefixed with VITE_ to be exposed to the client.

# Displayed in the sidebar, login page, and index.html title.
VITE_APP_NAME="Admin"

# Base URL for your backend API (used by future API adapters — fake API ignores this).
VITE_API_URL=""

# Default accent color preset: zinc | indigo | emerald | rose
VITE_DEFAULT_ACCENT="zinc"

# Default currency and locale used by formatCurrency / formatNumber.
VITE_DEFAULT_CURRENCY="USD"
VITE_DEFAULT_LOCALE="en-US"
